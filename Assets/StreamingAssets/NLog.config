<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false">

  <extensions>
    <add assembly="Assembly-CSharp" />
  </extensions>

  <targets>
    <target xsi:type="File"
            name="logfile"
            fileName="${specialfolder:folder=MyDocuments}/MyGame/Logs/game-${shortdate}.log"
            layout="${time} [${level:uppercase=true}] ${logger} - ${message}${when:when='${level:uppercase}' == 'ERROR' OR '${level:uppercase}' == 'FATAL':inner=${newline}${stacktrace:format=detailedFlat:topFrames=50:separator=
}}${onexception:inner=${newline}${exception:format=tostring}}"
            maxArchiveFiles="7"
            archiveEvery="Day"
            keepFileOpen="false"
            concurrentWrites="true" />

    <!-- stackTraceLevels 可按需调整，留空则全部不采集 -->
    <target xsi:type="UnityConsole"
            name="unityConsole"
            stackTraceLevels="Error,Fatal"
            layout="${time} [${level:uppercase=true}] ${logger} - ${message}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Debug" writeTo="logfile,unityConsole" />
  </rules>
</nlog>